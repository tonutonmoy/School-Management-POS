# Production environment template — copy to .env and fill all secrets

APP_ENV=production
APP_PORT=8085
APP_URL=https://school-management.tonusoft.com
APP_NAME=School Management System

POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://school:change-me-strong-password@db:5432/school_management?sslmode=disable

JWT_SECRET=generate-a-random-secret-at-least-64-characters-long-for-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

CSRF_SECRET=generate-a-random-csrf-secret-at-least-32-chars
RATE_LIMIT_MAX=200
RATE_LIMIT_EXPIRATION=1m

# SMTP (production email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@your-school-domain.com

# SMS (BulkSMSBD or log)
SMS_PROVIDER=bulksmsbd
SMS_API_KEY=
SMS_SENDER_ID=

# Cloudflare R2 / S3-compatible storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_PUBLIC_URL=

# Initial admin (used only on first boot if no admin exists)
ADMIN_EMAIL=admin@school.local
ADMIN_PASSWORD=Change-Me-Strong-Password-123!
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Administrator

# Do NOT set login pre-fill in production
LOGIN_EMAIL=
LOGIN_PASSWORD=

BACKUP_DIR=/app/backups
LOG_LEVEL=info
