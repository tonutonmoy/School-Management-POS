templ IncomeSummary(stats *dto.FinanceDashboardStats, csrf string, user *dto.AuthUser) {
	@layouts.Base("Income Summary", csrf, user, financeDashboardContent(stats))
}

templ MethodReport(stats *dto.FinanceDashboardStats, filter dto.FinanceReportFilter, csrf string, user *dto.AuthUser) {
	@layouts.Base("Collection By Method", csrf, user, methodReportContent(stats))
}

templ methodReportContent(stats *dto.FinanceDashboardStats) {
	<div>
		<h1 class="text-2xl font-bold">Collection By Method</h1>
		for _, m := range stats.PaymentMethodBreakdown {
			<div class="mt-2 flex justify-between rounded-lg border p-3">
				<span>{ m.Method }</span>
				<span>{ fmt.Sprintf("%.2f", m.Amount) } — { formatInt64(m.Count) }</span>
			</div>
		}
	</div>
}

templ FeeTypeReport(items []dto.FinanceTrendPoint, filter dto.FinanceReportFilter, csrf string, user *dto.AuthUser) {
	@layouts.Base("Fee Type Collection", csrf, user, feeTypeReportContent(items))
}

templ feeTypeReportContent(items []dto.FinanceTrendPoint) {
	<div>
		<h1 class="text-2xl font-bold">Fee Type Collection</h1>
		for _, i := range items {
			<div class="mt-2 flex justify-between rounded-lg border p-3"><span>{ i.Label }</span><span>{ fmt.Sprintf("%.2f", i.Amount) }</span></div>
		}
	</div>
}
