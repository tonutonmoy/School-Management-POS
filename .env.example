APP_ENV=development
APP_PORT=8085
APP_URL=http://localhost:8085
APP_NAME=School Management System

DATABASE_URL=postgresql://user:password@localhost:5432/school_management?sslmode=disable

JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

CSRF_SECRET=change-me-csrf-secret-key
RATE_LIMIT_MAX=100
RATE_LIMIT_EXPIRATION=1m

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_PUBLIC_URL=

ADMIN_EMAIL=admin@school.local
ADMIN_PASSWORD=Admin@123456
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Administrator

# Login page pre-fill (shown by default on /login)
LOGIN_EMAIL=admin@school.local
LOGIN_PASSWORD=Admin@123456

LOG_LEVEL=info

# SMTP (optional — overrides DB settings when set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# SMS gateway
SMS_PROVIDER=log
SMS_API_KEY=
SMS_SENDER_ID=

# Backup storage directory
BACKUP_DIR=./backups
